PORT=3000

# Your MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hostelbloom?retryWrites=true&w=majority

# Your Google Gemini API key for the Chatbot functionality
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key for Fast LLM Chatbot Fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Backend Auth Token Secret
JWT_SECRET=supersecret_hostelbloom_token
JWT_EXPIRES_IN=1d

# Resend API Key for Email Delivery
RESEND_API_KEY=your_resend_api_key

# Address emails should be sent FROM (must be a verified domain in Resend)
EMAIL_FROM=HostelBloom <noreply@yourdomain.com>

# Email address to receive Contact Form messages (The Admin Inbox)
ADMIN_CONTACT_EMAIL=hostelblooom@gmail.com
