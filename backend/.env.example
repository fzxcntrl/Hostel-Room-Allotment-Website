PORT=3000

# Your MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.abc.mongodb.net/hostelbloom?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://...

# Authentication Secret
JWT_SECRET=super_secret_jwt_key_2026
JWT_EXPIRES_IN=1d

# Your Google Gemini API key for the Chatbot functionality
GEMINI_API_KEY=your_gemini_api_key_here
